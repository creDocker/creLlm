RUN uv pip list

# Freeze python requirements here:
RUN mkdir -p /cre && \ 
    uv pip freeze --no-cache-dir > /cre/requirements.txt.orig

RUN mkdir -p /cre && touch /cre/versions.txt && \ 
   echo "$(date +'%F %R') \t creLLM \t $TENSORFLOW_VERSION" >> /cre/versions.txt && \ 
   echo "$(date +'%F %R') \t  node \t $(node --version)" >> /cre/versions.txt && \
   echo "$(date +'%F %R') \t  npm \t $(npm --version)" >> /cre/versions.txt && \ 
   echo "$(date +'%F %R') \t  $(uv pip list | grep 'ollama ')" >> /cre/versions.txt


